# ============================================================
# Automotive CS03 AI Copilot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# AI / LLM API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-5

GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash-lite

# ------------------------------------------------------------
# MySQL — same server, per-agent schemas
# ------------------------------------------------------------
MYSQL_USER=cs03_user
MYSQL_PASSWORD=your_strong_password_here
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Per-agent database schemas (all on same MySQL server)
MYSQL_DB_VEHICLE=cs03_vehicle
MYSQL_DB_WARRANTY=cs03_warranty
MYSQL_DB_SCHEDULER=cs03_scheduler
MYSQL_DB_TELEMATICS=cs03_telematics
MYSQL_DB_AUTH=cs03_auth
MYSQL_DB_AGENT=cs03_agent

# ------------------------------------------------------------
# ChromaDB (vector store for RAG)
# ------------------------------------------------------------
CHROMA_PATH=/app/chroma_db
KNOWLEDGE_DIR=/app/knowledge_base

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development
SECRET_KEY=generate-a-long-random-secret-here
CORS_ORIGINS=["http://localhost:4200"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
